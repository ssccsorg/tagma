# ============================================================
# Logs and temporary files
# ============================================================
**/*.log
**/*.bak
**/*.backup

# ============================================================
# Python
# ============================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.ipynb_checkpoints/

# ============================================================
# Quarto (docs)
# ============================================================
**/*_cached*
**/*quarto_ipynb*
/docs/**/*_files
/docs/**/*_output
/docs/**/*_extensions 
/docs/**/*_llms
/docs/**/*_libs
/docs/**/*.tex
/docs/**/*.pdf
/docs/**/*.html
/docs/**/*.c2pa_identifier.svg

# Global Quarto
**/*.quarto_ipynb
**/*.quarto
**/*_site

# ============================================================
# Node / Tauri
# ============================================================
**/node_modules/
**/dist/
**/.vite/

# ============================================================
# Rust / Cargo
# ============================================================
**/target/

# ============================================================
# C2PA
# ============================================================
**/*.c2pa

# ============================================================
# Configuration directories
# ============================================================
**/.*
!**/.gitignore
!**/.gitattributes
!**/.github/
!**/.vscode/
!**/.devcontainer/
!**/.dockerignore

# ============================================================
# docs/build.py
# ============================================================
_docsbuild/
_publish/
_agent/
_pages/
_jupyter_cache/
